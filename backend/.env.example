# MongoDB connection URI (e.g. MongoDB Atlas cluster string)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/studysync?retryWrites=true&w=majority

# Secret key used for signing JWT authentication tokens
JWT_SECRET=your_long_random_jwt_secret_key_here

# Port number for the Express server to listen on
PORT=5000

# CORS Allowed Origin (set to your Vercel frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# Node Environment ('development' or 'production')
NODE_ENV=production

# Gemini AI API Key (Optional: Provide to enable real AI assistant features)
GEMINI_API_KEY=your_gemini_api_key_here
